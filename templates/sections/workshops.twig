<!-- Workshops Page -->
<div class="container">
    <h1>Workshopy</h1>

    {% set totalWorkshops = workshops_no_timeslot|length %}
    {% for ts in timeslots %}
        {% set totalWorkshops = totalWorkshops + (workshops_by_timeslot[ts.code] ?? [])|length %}
    {% endfor %}

    {% if totalWorkshops == 0 %}
        <div class="card">
            <div class="card__body">
                <p>Momentálně nejsou k dispozici žádné workshopy. Zkuste to prosím později.</p>
            </div>
        </div>
    {% else %}

        {% for ts in timeslots %}
            {% set group = workshops_by_timeslot[ts.code] ?? [] %}
            {% if group is not empty %}
                <section class="workshops-timeslot-section">
                    <h2 class="workshops-timeslot-heading  random{{ random(9) }} ">
                        {{ ts.name }}
                        <span class="workshops-timeslot-code">({{ ts.code }})</span>
                    </h2>
                    <div class="workshops-grid">
                        {% for workshop in group %}
                            {{ _self.workshopCard(workshop, user, people_by_workshop[workshop.id] ?? [], photo, ts.name) }}
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        {% endfor %}

        {% if workshops_no_timeslot is not empty %}
            <section class="workshops-timeslot-section">
                <h2 class="workshops-timeslot-heading">Ostatní workshopy</h2>
                <div class="workshops-grid">
                    {% for workshop in workshops_no_timeslot %}
                        {{ _self.workshopCard(workshop, user, people_by_workshop[workshop.id] ?? [], photo, '') }}
                    {% endfor %}
                </div>
            </section>
        {% endif %}

    {% endif %}
</div>

{% macro workshopCard(workshop, user, lidi,fotky,timeslot_nazev) %}
    {% set isFull = workshop.available_spots <= 0 %}
    {% set progressPercent = (workshop.registered / workshop.capacity * 100)|round %}
    
    <div class="workshop-card {{ isFull ? 'full' : '' }}" data-workshop-id="{{ workshop.id }}" id="workshop-{{ workshop.id }}">
        <div class="workshop-header">
            <h3 class="workshop-title">{{ workshop.name }} </h3>
            {% if workshop.instructor %}
                <div class="workshop-instructor">Lektor: {{ workshop.instructor }}</div>
            {% endif %}
        </div>

        <div class="workshop-body">
            {% if workshop.description %}
                <p >{{ workshop.description|raw|nl2br|cz_nbsp }}</p>
            {% endif %}
            
            <div class="workshop-details">
                <div class="workshop-detail-item">
                    <strong>Datum:</strong> {{ workshop.date|date('j.n.Y') }}
                </div>
                <div class="workshop-detail-item">
                    <strong>Čas:</strong> {{ workshop.time[:5] }}
                </div>
                <div class="workshop-detail-item">
                    <strong>Délka:</strong> {{ workshop.duration_minutes }} min
                </div>
                {% if workshop.location %}
                    <div class="workshop-detail-item">
                        <strong>Místo:</strong> {{ workshop.location }}
                    </div>
                {% endif %}
                <div class="workshop-detail-item">
                    <strong>Úroveň:</strong>
                    <span >
                        {{ workshop.level }}
                        
                    </span>
                </div>
            </div>

            <div class="workshop-info">
                <div class="workshop-timeslot">{{ timeslot_nazev }} </div>
                <div class="workshop-price">{{ workshop.price|number_format(0, ',', ' ') }} Kč</div>
                <div class="capacity-info {{ isFull ? 'capacity-full' : '' }}">
                    {{ workshop.registered }}/{{ workshop.capacity }} míst obsazeno<br>
                    Eviduji {{ workshop.enrolled_count }} registrací
                    {% if isFull %}
                        <span class="full-badge">PLNÉ</span>
                    {% endif %}
                </div>
            </div>

            <div class="capacity-bar">
                <div class="capacity-fill" style="width: {{ progressPercent }}%"></div>
            </div>

            {% if user %}
                {% if isFull %}
                    <button class="btn btn--secondary btn--block" disabled>Workshop je plný</button>
                {% else %}          
                    <!-- Bylo tu tlačítko registrovat -->
                {% endif %}
            {% else %}
                <!--<a href="#" onclick="document.getElementById('login-btn').click(); return false;" class="btn btn--primary btn--block">
                    Přihlaste se pro registraci
                </a>-->
            {% endif %}
        </div>
    </div>


     {% for person in lidi %}
                        <div class="person-card card" style="margin-bottom:8px;">
                            <div class="card__body">

                                <h3 class="person-card__name" style="margin-bottom:4px;">{{ person.name }}</h3>
                                {% if fotky[person.id] %}
                                <img style="float:right;width:12em;margin-left:3em;margin-bottom:1em;
                                border:thick solid grey;
                                " src="img/{{fotky[person.id]}}" alt="Medailonek osoby"/>
                                {% endif %}
                                <div class="person-card__links">
                                    {% if person.weblink %}
                                        <a href="{{ person.weblink }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--web" title="Web">
                                            Web
                                        </a>
                                    {% endif %}
                                    {% if person.fblink %}
                                        <a href="{{ person.fblink }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--fb" title="Facebook">
                                            FB
                                        </a>
                                    {% endif %}
                                    {% if person.instagramlink %}
                                        <a href="{{ person.instagramlink }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--ig" title="Instagram">
                                            IG
                                        </a>
                                    {% endif %}
                                <br>
                                {% if person.description %}
                                    <p class="person-card__description">{{ person.description |raw|nl2br |cz_nbsp }}</p>
                                {% endif %}


                                </div>
                            </div>
                        </div>
                    {% endfor %}





     
{% endmacro %}

<style>
.workshops-timeslot-section {
    margin-bottom: 2.5rem;
}
.workshops-timeslot-heading {
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-primary, #c0392b);
}
.workshops-timeslot-code {
    font-size: 0.85rem;
    font-weight: normal;
    color: var(--color-muted, #777);
}
</style>
