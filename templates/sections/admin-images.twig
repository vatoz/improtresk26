{# ── Existing images gallery ──────────────────────────────────────────── #}
<div class="card">
    <div class="card__body">
        <h3 style="margin-top:0; margin-bottom:1rem;">Nahrané obrázky ({{ images|length }})</h3>

        {% if images is empty %}
            <p style="color:var(--color-text-secondary);">Žádné obrázky.</p>
        {% else %}
            <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(130px,1fr)); gap:1rem;">
                {% for img in images %}
                    <div style="text-align:center; border:1px solid var(--color-border,#ddd); border-radius:4px; padding:.5rem;">
                        <img src="/img/{{ img.name }}" alt="{{ img.name }}"
                             style="max-width:100%; max-height:90px; object-fit:contain; display:block; margin:0 auto .4rem;">
                        <code style="font-size:.7rem; word-break:break-all;">{{ img.name }}</code><br>
                        <small style="color:var(--color-text-secondary);">{{ (img.size / 1024)|round(1) }} kB</small>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
