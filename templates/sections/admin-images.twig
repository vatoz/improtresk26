{% if success %}
    <div class="notification notification--success" style="margin-bottom:1rem;">{{ success }}</div>
{% endif %}
{% if error %}
    <div class="notification notification--error" style="margin-bottom:1rem;">{{ error }}</div>
{% endif %}

{# ── People without image ─────────────────────────────────────────────── #}
<div class="card" style="margin-bottom:1.5rem;">
    <div class="card__body">
        <h3 style="margin-top:0; margin-bottom:.25rem;">Lidé bez obrázku</h3>
        <p style="margin:0 0 1rem; color:var(--color-text-secondary); font-size:var(--font-size-sm);">
            Nahraje se jako <code>{id}.jpg</code> nebo <code>{id}.png</code> 
            <br>Maximální velikost je 200 kB
        </p>

        {% if unpaired_people is empty %}
            <p style="color:var(--color-text-secondary);">Všichni lidé mají obrázek.</p>
        {% else %}
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width:3rem;">ID</th>
                        <th>Jméno</th>
                        <th>Sekce</th>
                        <th>Nahrát obrázek</th>
                    </tr>
                </thead>
                <tbody>
                    {% for person in unpaired_people %}
                        <tr>
                            <td style="color:var(--color-text-secondary);">{{ person.id }}</td>
                            <td><strong>{{ person.name }}</strong></td>
                            <td style="color:var(--color-text-secondary);">{{ person.section }}</td>
                            <td>
                                <form method="post" action="/admin/images/upload"
                                      enctype="multipart/form-data"
                                      style="display:flex; gap:.5rem; align-items:center; flex-wrap:wrap;">
                                    <input type="hidden" name="_csrf" value="{{ csrf }}">
                                    <input type="hidden" name="target_type" value="person">
                                    <input type="hidden" name="target_id" value="{{ person.id }}">
                                    <input type="file" name="image" accept=".jpg,.png"
                                           class="form-control" style="max-width:220px;" required>
                                    <button type="submit" class="btn btn--primary btn--sm">Nahrát</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

