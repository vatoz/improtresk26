<!-- Harmonogram Page -->
<div class="container">
    <h1>Harmonogram festivalu</h1>

    {% if program_items is empty %}
        <div class="card">
            <div class="card__body">
                <p>Program festivalu bude brzy zveřejněn. Sledujte naše stránky pro aktualizace.</p>
            </div>
        </div>
    {% else %}
        <div class="program-grid">
            {% for date, slots in program_items %}
                <div class="program-day">
                    <h2 class="program-day-title">{{ date|date('j. n. Y') }}</h2>

                    {% for slot in slots %}
                        <div class="program-timeslot">
                            {% if slot.full_width %}
                                {# Full-width item spanning both tracks #}
                                {% set item = slot.full_width %}
                                <div class="program-item program-item--full">
                                    <div class="program-content">
                                        <div class="program-header">
                                            <h3 class="program-title">
                                              {{ slot.start_time[:5] |trimStartZero}} - {{ slot.end_time[:5] |trimStartZero}}
                                            
                                            {{ item.title }}</h3>
                                            <span class="program-type badge badge-{{ item.type }}">
                                                {% if item.type == 'performance' %}Představení
                                                {% elseif item.type == 'workshop' %}Workshop
                                                {% elseif item.type == 'discussion' %}Diskuse
                                                {% elseif item.type == 'party' %}Párty
                                                {% else %}{{ item.type }}
                                                {% endif %}
                                            </span>
                                        </div>

                                        {% if item.performer %}
                                            <div class="program-performer">{{ item.performer }}</div>
                                        {% endif %}

                                        {% if item.description %}
                                            <p class="program-description">{{ item.description |raw|nl2br|cz_nbsp}}</p>
                                        {% endif %}

                                        <div class="program-details">
                                            {% if item.location %}
                                                <span class="program-location">📍 {{ item.location }}</span>
                                            {% endif %}
                                            {% if item.is_free %}
                                                <span class="program-free">🎫 Vstup zdarma</span>
                                            {% endif %}
                                            {% if item.max_capacity %}
                                                <span class="program-capacity">👥 Kapacita: {{ item.max_capacity }}</span>
                                            {% endif %}
                                        </div>
                                        {% if program_info_map[item.id] is defined %}
                                            <a href="/program#program_{{ program_info_map[item.id] }}" class="program-read-more">Číst víc...</a>
                                        {% endif %}
                                    </div>
                                </div>
                            {% else %}
                                {# Concurrent tracks — always two columns #}
                                <div class="program-tracks">
                                    {% for track_key, track_label in {'track_a': 'Blok A', 'track_b': 'Blok B'} %}
                                        {% set track_data = slot[track_key] %}
                                        <div class="program-track">
                                           <!-- <div class="program-track-label">{{ track_label }}</div>-->

                                            {# Top spacer: empty time before this track's item starts #}
                                            {% if track_data.start_offset_mins > 0 %}
                                                <div class="program-track-spacer"
                                                     style="min-height: {{ track_data.start_offset_mins * 2 }}px">
                                                    <span class="program-spacer-text">Volno</span>
                                                </div>
                                            {% endif %}

                                            {% if track_data.item %}
                                                {% set item = track_data.item %}
                                                <div class="program-item">
                                                    <div class="program-content">
                                                        <div class="program-header">
                                                            <h3 class="program-title">   {{ item.start_time[:5] |trimStartZero}} - {{ item.end_time[:5] |trimStartZero}} {{ item.title }}</h3>
                                                            <span class="program-type badge badge-{{ item.type }}">
                                                                {% if item.type == 'performance' %}Představení
                                                                {% elseif item.type == 'workshop' %}Workshop
                                                                {% elseif item.type == 'discussion' %}Diskuse
                                                                {% elseif item.type == 'party' %}Párty
                                                                {% else %}{{ item.type }}
                                                                {% endif %}
                                                            </span>
                                                        </div>

                                                        {% if item.performer %}
                                                            <div class="program-performer">{{ item.performer }}</div>
                                                        {% endif %}

                                                        {% if item.description %}
                                                            <p class="program-description">{{ item.description|raw|nl2br|cz_nbsp }}</p>
                                                        {% endif %}

                                                        <div class="program-details">
                                                            {% if item.location %}
                                                                <span class="program-location">📍 {{ item.location }}</span>
                                                            {% endif %}
                                                            {% if item.is_free %}
                                                                <span class="program-free">🎫 Vstup zdarma</span>
                                                            {% endif %}
                                                            {% if item.max_capacity %}
                                                                <span class="program-capacity">👥 Kapacita: {{ item.max_capacity }}</span>
                                                            {% endif %}
                                                        </div>
                                                        {% if program_info_map[item.id] is defined %}
                                                            <a href="/program#program_{{ program_info_map[item.id] }}" class="program-read-more">Číst víc...</a>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            {% else %}
                                                <div class="program-item program-item--empty">
                                                    <div class="program-content">
                                                        <p class="program-empty-text">Žádný program</p>
                                                    </div>
                                                </div>
                                            {% endif %}

                                            {# Bottom spacer: empty time after this track's item ends #}
                                            {% if track_data.end_offset_mins > 0 %}
                                                <div class="program-track-spacer"
                                                     style="min-height: {{ track_data.end_offset_mins * 2 }}px">
                                                    <span class="program-spacer-text">Volno</span>
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
