<div class="container">
    <h1>Medailonky</h1>

    {% if people is empty %}
        <div class="card">
            <div class="card__body">
                <p>Momentálně nejsou k dispozici žádné medailonky.</p>
            </div>
        </div>
    {% else %}
        {% for section, members in people %}
            <section class="people-section" style="padding-top:15px;padding-bottom:5px;">
                <h2 class="people-section__title random{{ random(9) }}">{{ section }}</h2>
                <div class="people-grid">
                    {% for person in members %}
                        <div class="person-card card" style="margin-bottom:8px;">
                            <div class="card__body">
                                                               
                                <h3 class="person-card__name" style="margin-bottom:4px;">{{ person.name }}</h3>
                                {% if photo[person.id] %}
                                <img style="float:right;width:12em;margin-left:3em;margin-bottom:1em;
                                border:thick solid grey;
                                " src="img/{{photo[person.id]}}" alt="Medailonek osoby"/>
                                {% endif %}
                                <div class="person-card__links">
                                    {% if person.weblink %}
                                        <a href="{{ person.weblink }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--web" title="Web">
                                            Web 
                                        </a>
                                    {% endif %}
                                    {% if person.fblink %}
                                        <a href="{{ person.fblink }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--fb" title="Facebook">
                                            FB 
                                        </a>
                                    {% endif %}
                                    {% if person.instagramlink %}
                                        <a href="{{ person.instagramlink }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--ig" title="Instagram">
                                            IG 
                                        </a>
                                    {% endif %}
                                <br>
                                {% if person.description %}
                                    <p class="person-card__description">{{ person.description |raw|nl2br |cz_nbsp }}</p>
                                {% endif %}

                                {% if person.workshops is not empty %}
                                    <div class="person-card__workshops">
                                        {% for ws in person.workshops %}
                                            <a href="/workshops#workshop-{{ ws.id }}" class="btn btn--sm btn--outline person-card__workshop-link">
                                                {{ ws.name }}
                                            </a>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% endfor %}
    {% endif %}
</div>
