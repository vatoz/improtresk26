<div class="container">
    <h1>Program</h1>

    {% if program_info is empty %}
        <div class="card">
            <div class="card__body">
                <p>Momentálně nejsou k dispozici žádné informace o programu.</p>
            </div>
        </div>
    {% else %}
        {% for group, items in program_info %}
            <section class="people-section" style="padding-top:15px;padding-bottom:5px;" id="sekce_{{ group|replace({' ': '_'}) }}">
                <h2 class="people-section__title random{{ random(9) }}">{{ group }}</h2>
                <div class="people-grid">
                    {% for item in items %}
                        <div class="person-card card" style="margin-bottom:8px;">
                            <div class="card__body">
                                {% if item.photo %}
                                <img class="program_foto"
                                " src="img/{{item.photo}}" alt="Promo foto"/>
                                {% endif %}
                                <h3 class="person-card__name" style="margin-bottom:4px;" id="program_{{ item.id }}">{{ item.name }}</h3>
                                <div class="person-card__links">
                                    {% if item.web_link %}
                                        <a href="{{ item.web_link }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--web" title="Web">
                                            Web
                                        </a>
                                    {% endif %}
                                    {% if item.facebook_link %}
                                        <a href="{{ item.facebook_link }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--fb" title="Facebook">
                                            FB
                                        </a>
                                    {% endif %}
                                    {% if item.instagram_link %}
                                        <a href="{{ item.instagram_link }}" target="_blank" rel="noopener noreferrer" class="person-card__link person-card__link--ig" title="Instagram">
                                            IG
                                        </a>
                                    {% endif %}
                                <br>
                                {% if item.description %}
                                    <p class="person-card__description">{{ item.description|raw|nl2br|cz_nbsp }}</p>
                                {% endif %}

                                {% if item.program_item_title %}
                                    
                                    <div class="card_details_program">
                                       
                                    
                                    {{ item.date|date('j. n. Y') }}  {{ item.start_time[:5] }} <br>
                                    {{ item.location }}


                                    </div>
                                {% endif %}

                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% endfor %}
    {% endif %}
</div>
