{% set reg_labels = {
    pending:    'Čeká',
    paid:       'Zaplaceno',
    approved:   'Vylosováno',
    upgradable: 'Možný upgrade',
    notpaid:    'Nezaplaceno',
    cancelled:  'Zrušeno',
    refunded:   'Vráceno',
    skipped:    'Přeskočeno'
} %}
{% set purch_labels = {
    pending:   'Čeká',
    paid:      'Zaplaceno',
    cancelled: 'Zrušeno'
} %}

{% set back_url = '/admin/users/' ~ profile_user.id %}

<a href="/admin/users" class="btn btn--sm" style="margin-bottom:1rem;">&larr; Zpět na seznam uživatelů</a>

{# ── User info ── #}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <div class="pairing-tx-meta">
            <strong style="font-size:1.1rem;">{{ profile_user.name }}</strong>
            <a href="mailto:{{ profile_user.email }}">{{ profile_user.email }}</a>
            {% if profile_user.hero > 0 %}
                <span class="pairing-badge pairing-badge--hero">
                    {{ profile_user.hero == 1 ? 'Hrdina' : 'Hrdinka' }}
                </span>
            {% endif %}
        </div>
        <div class="pairing-tx-status">
            <span class="pairing-tx-date" style="font-size:0.85rem;">Registrace: {{ profile_user.created_at|date('j.n.Y') }}</span>
        </div>
    </div>
</div>

{# ── Awaiting payment ── #}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <strong>Čekající platba</strong>
        <span class="pairing-tx-date">
            Aktuálně:
            {% if profile_user.awaiting_payment > 0 %}
                <strong style="color:#d68910;">{{ profile_user.awaiting_payment|number_format(2, ',', ' ') }} Kč</strong>
            {% else %}
                <span style="color:#999;">0 Kč</span>
            {% endif %}
        </span>
    </div>
    <div class="pairing-section">
        <form method="POST" action="/admin/users/{{ profile_user.id }}/set-awaiting-payment"
              style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="number" name="awaiting_payment" step="0.01" min="0"
                   value="{{ profile_user.awaiting_payment }}"
                   class="pairing-select" style="width:10rem;" required>
            <span style="font-size:0.9rem;color:#666;">Kč</span>
            <button type="submit" class="btn btn--sm btn--primary">Uložit</button>
            <span style="font-size:0.8rem;color:#999;">(0 = žádná čekající platba)</span>
        </form>
    </div>
</div>

{# ── Send mail ── #}
{% if mail_sent %}
<div class="pairing-alert pairing-alert--ok">
    E-mail byl zařazen do fronty k odeslání.
</div>
{% endif %}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <strong>Odeslat e-mail</strong>
    </div>
    <div class="pairing-section" style="display:flex;gap:0.6rem;flex-wrap:wrap;padding:1rem 1.25rem;">
        <form method="POST" action="/admin/users/{{ profile_user.id }}/send-mail"
              onsubmit="return confirm('Opravdu odeslat e-mail „Uvítací e-mail" uživateli {{ profile_user.name }}?')">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="hidden" name="mail_type" value="registration">
            <button type="submit" class="btn btn--sm">Uvítací e-mail</button>
        </form>
        <form method="POST" action="/admin/users/{{ profile_user.id }}/send-mail"
              onsubmit="return confirm('Opravdu odeslat e-mail „Potvrzení platby" uživateli {{ profile_user.name }}?')">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="hidden" name="mail_type" value="payment-confirmed">
            <button type="submit" class="btn btn--sm btn--success">Potvrzení platby</button>
        </form>
        <form method="POST" action="/admin/users/{{ profile_user.id }}/send-mail"
              onsubmit="return confirm('Opravdu odeslat e-mail „Program" uživateli {{ profile_user.name }}?')">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="hidden" name="mail_type" value="schedule">
            <button type="submit" class="btn btn--sm btn--primary">Program</button>
        </form>
        <form method="POST" action="/admin/users/{{ profile_user.id }}/send-mail"
              onsubmit="return confirm('Opravdu odeslat e-mail „Obnova hesla" uživateli {{ profile_user.name }}?')">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="hidden" name="mail_type" value="password-reset">
            <button type="submit" class="btn btn--sm">Obnova hesla</button>
        </form>
    </div>
    {% if mail_templates is not empty %}
    <div style="border-top:1px solid var(--color-border,#eee);padding:0.75rem 1.25rem;display:flex;gap:0.6rem;align-items:center;flex-wrap:wrap;">
        <form method="POST" action="/admin/users/{{ profile_user.id }}/send-mail"
              onsubmit="return confirm('Opravdu odeslat vybranou šablonu uživateli {{ profile_user.name }}?')">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <input type="hidden" name="mail_type" value="template">
            <select name="template_id" class="pairing-select" required>
                <option value="">— vyberte šablonu —</option>
                {% for tpl in mail_templates %}
                    <option value="{{ tpl.id }}">{{ tpl.title }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn--sm btn--primary" style="margin-left:0.3rem;">Odeslat šablonu</button>
        </form>
    </div>
    {% endif %}
</div>

{# ── Registrations ── #}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <strong>Workshopy</strong>
        <span class="pairing-tx-date">{{ registrations|length }} záznamů</span>
    </div>
    {% if registrations is not empty %}
    <div class="pairing-section">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Workshop</th>
                    <th>Termín</th>
                    <th>Cena</th>
                    <th>Stav</th>
                    <th title="Počet aktivních registrací s dřívějším created_at na stejný workshop">Pořadí</th>
                    <th>Změnit stav</th>
                </tr>
            </thead>
            <tbody>
                {% for reg in registrations %}
                <tr class="pairing-row pairing-row--{{ reg.payment_status }}">
                    <td>{{ reg.workshop_name ?? '–' }}</td>
                    <td>{{ reg.timeslot }}</td>
                    <td>{{ reg.price is not null ? reg.price|number_format(0, ',', ' ') ~ ' Kč' : '–' }}</td>
                    <td>
                        <span class="pairing-status pairing-status--{{ reg.payment_status }}">
                            {{ reg_labels[reg.payment_status] ?? reg.payment_status }}
                        </span>
                        {% if threshold > reg.created_at|date('U') and reg.payment_status == 'pending' %}
                            , po termínu {{ reg.created_at }}
                        {% endif %}
                    </td>
                    <td class="pairing-queue">
                        {% if reg.queue_position is not null %}
                            <span title="Kolikátý teď jsem">{{ reg.queue_position + 1 }}.</span>/<span title="Kolik mám zaplacených registrací">{{ reg.registered }}</span>/<span title="Kapacita">{{ reg.capacity }}</span>
                        {% else %}
                            –
                        {% endif %}
                    </td>
                    <td>
                        <form method="POST" action="/admin/pairing/set-registration-status" class="pairing-status-form">
                            <input type="hidden" name="_csrf" value="{{ csrf }}">
                            <input type="hidden" name="registration_id" value="{{ reg.id }}">
                            <input type="hidden" name="back" value="{{ back_url }}">
                            <select name="status" class="pairing-select">
                                {% for val, label in reg_labels %}
                                    <option value="{{ val }}" {% if val == reg.payment_status %}selected{% endif %}>{{ label }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn--sm btn--primary">Uložit</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="pairing-empty">Žádné registrace.</p>
    {% endif %}
    {% if all_workshops is not empty %}
    <div style="border-top:1px solid var(--color-border,#eee);padding:0.75rem 1.25rem;">
        <form method="POST" action="/admin/users/{{ profile_user.id }}/add-registration"
              style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <select name="workshop_id" class="pairing-select" required>
                <option value="">— vyberte workshop —</option>
                {% for w in all_workshops %}
                    <option value="{{ w.id }}">[{{ w.timeslot }}] {{ w.name }}{% if w.price %} ({{ w.price|number_format(0, ',', ' ') }} Kč){% endif %}</option>
                {% endfor %}
            </select>
            <select name="payment_status" class="pairing-select">
                {% for val, label in reg_labels %}
                    <option value="{{ val }}" {% if val == 'pending' %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn--sm btn--primary">Přidat registraci</button>
        </form>
    </div>
    {% endif %}
</div>

{# ── Purchases ── #}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <strong>Nákupy</strong>
        <span class="pairing-tx-date">{{ purchases|length }} záznamů</span>
    </div>
    {% if purchases is not empty %}
    <div class="pairing-section">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Položka</th>
                    <th>Typ</th>
                    <th>Ks</th>
                    <th>Cena</th>
                    <th>Stav</th>
                    <th>Změnit stav</th>
                </tr>
            </thead>
            <tbody>
                {% for p in purchases %}
                <tr class="pairing-row pairing-row--{{ p.payment_status }}">
                    <td>{{ p.item_name ?? '–' }}</td>
                    <td>
                        {% if p.item_type == 'ticket' %}
                            <span class="type-badge type-badge--ticket">Vstupenka</span>
                        {% else %}
                            <span class="type-badge type-badge--merch">Merch</span>
                        {% endif %}
                    </td>
                    <td>{{ p.quantity }}</td>
                    <td>{{ p.price is not null ? p.price|number_format(0, ',', ' ') ~ ' Kč' : '–' }}</td>
                    <td>
                        <span class="pairing-status pairing-status--{{ p.payment_status }}">
                            {{ purch_labels[p.payment_status] ?? p.payment_status }}
                        </span>
                    </td>
                    <td>
                        <form method="POST" action="/admin/pairing/set-purchase-status" class="pairing-status-form">
                            <input type="hidden" name="_csrf" value="{{ csrf }}">
                            <input type="hidden" name="purchase_id" value="{{ p.id }}">
                            <input type="hidden" name="back" value="{{ back_url }}">
                            <select name="status" class="pairing-select">
                                {% for val, label in purch_labels %}
                                    <option value="{{ val }}" {% if val == p.payment_status %}selected{% endif %}>{{ label }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn--sm btn--primary">Uložit</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="pairing-empty">Žádné nákupy.</p>
    {% endif %}
    {% if all_tickets is not empty %}
    <div style="border-top:1px solid var(--color-border,#eee);padding:0.75rem 1.25rem;">
        <form method="POST" action="/admin/users/{{ profile_user.id }}/add-purchase"
              style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
            <input type="hidden" name="_csrf" value="{{ csrf }}">
            <select name="ticket_id" class="pairing-select" required>
                <option value="">— vyberte vstupenku —</option>
                {% for t in all_tickets %}
                    <option value="{{ t.id }}">{{ t.name }}{% if t.price %} ({{ t.price|number_format(0, ',', ' ') }} Kč){% endif %}</option>
                {% endfor %}
            </select>
            <select name="payment_status" class="pairing-select">
                {% for val, label in purch_labels %}
                    <option value="{{ val }}" {% if val == 'pending' %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn--sm btn--primary">Přidat vstupenku</button>
        </form>
    </div>
    {% endif %}
</div>

{# ── Questions & Answers ── #}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <strong>Odpovědi na otázky</strong>
        <span class="pairing-tx-date">{{ questions_with_answers|length }} otázek</span>
    </div>
    {% if questions_with_answers is not empty %}
    <div class="pairing-section">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Otázka</th>
                    <th>Odpověď</th>
                    <th>Aktualizováno</th>
                </tr>
            </thead>
            <tbody>
                {% for qa in questions_with_answers %}
                <tr>
                    <td style="max-width:260px;">
                        {{ qa.question }}
                        {% if qa.is_required %}<span style="color:#c0392b;" title="Povinná">*</span>{% endif %}
                    </td>
                    <td>
                        {% if qa.value is not null %}
                            {% if qa.type == 'yes_no' %}
                                <span class="pairing-status {% if qa.value == '1' or qa.value == 'yes' %}pairing-status--paid{% else %}pairing-status--cancelled{% endif %}">
                                    {{ (qa.value == '1' or qa.value == 'yes') ? 'Ano' : 'Ne' }}
                                </span>
                            {% else %}
                                {{ qa.value }}
                            {% endif %}
                        {% else %}
                            <span style="color:#bbb;">—</span>
                        {% endif %}
                    </td>
                    <td style="white-space:nowrap;font-size:0.83rem;color:#888;">
                        {{ qa.updated_at ? qa.updated_at|date('j.n.Y H:i') : '—' }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="pairing-empty">Žádné otázky.</p>
    {% endif %}
</div>

{# ── Sent mails ── #}
<div class="pairing-card">
    <div class="pairing-tx-header">
        <strong>Odeslané e-maily</strong>
        <span class="pairing-tx-date">{{ sent_mails|length }} záznamů</span>
    </div>
    {% if sent_mails is not empty %}
    <div class="pairing-section">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Předmět</th>
                    <th>Šablona</th>
                    <th>Stav</th>
                    <th>Zařazeno</th>
                    <th>Odesláno</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for mail in sent_mails %}
                <tr>
                    <td>{{ mail.subject }}</td>
                    <td style="font-size:0.82rem;color:#888;font-family:monospace;">{{ mail.template ?? '—' }}</td>
                    <td>
                        <span class="pairing-status
                            {% if mail.status == 'sent' %}pairing-status--paid
                            {% elseif mail.status == 'failed' %}pairing-status--notpaid
                            {% else %}pairing-status--pending{% endif %}">
                            {% if mail.status == 'sent' %}Odesláno
                            {% elseif mail.status == 'failed' %}Chyba
                            {% else %}Čeká{% endif %}
                        </span>
                    </td>
                    <td style="white-space:nowrap;font-size:0.83rem;color:#888;">{{ mail.queued_at|date('j.n.Y H:i') }}</td>
                    <td style="white-space:nowrap;font-size:0.83rem;color:#888;">{{ mail.sent_at ? mail.sent_at|date('j.n.Y H:i') : '—' }}</td>
                    <td>
                        <button class="btn btn--sm"
                                onclick="openMailPreview({{ mail.id }}, {{ mail.subject|json_encode }})">
                            Náhled
                        </button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="pairing-empty">Žádné e-maily.</p>
    {% endif %}
</div>

{# Preview modal #}
<div id="mail-preview-modal" class="modal hidden">
    <div class="modal-content" style="width:90%; max-width:900px;">
        <div class="modal-header">
            <h3 id="mail-preview-title" style="font-size:1rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></h3>
            <button class="modal-close" onclick="closeMailPreview()">&times;</button>
        </div>
        <iframe id="mail-preview-frame"
                src=""
                style="width:100%; height:70vh; border:none; display:block;"></iframe>
    </div>
</div>

<script>
function openMailPreview(id, subject) {
    document.getElementById('mail-preview-title').textContent = subject;
    document.getElementById('mail-preview-frame').src = '/admin/mail-queue/' + id + '/preview';
    document.getElementById('mail-preview-modal').classList.remove('hidden');
}
function closeMailPreview() {
    document.getElementById('mail-preview-modal').classList.add('hidden');
    document.getElementById('mail-preview-frame').src = '';
}
document.getElementById('mail-preview-modal').addEventListener('click', function(e) {
    if (e.target === this) closeMailPreview();
});
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMailPreview();
});
</script>

{# ── Transactions ── #}
<h3 style="margin: 1.5rem 0 0.75rem;">Transakce ({{ transactions|length }})</h3>

{% if transactions is empty %}
    <p class="pairing-empty" style="padding:0;">Žádné spárované transakce.</p>
{% else %}
    {% for tx in transactions %}
    <div class="pairing-card {% if tx.completed %}pairing-card--done{% endif %}" id="transaction-{{ tx.id }}">
        <div class="pairing-tx-header">
            <div class="pairing-tx-meta">
                <span class="pairing-tx-date">{{ tx.date }}</span>
                <span class="pairing-tx-amount {% if tx.amount_int < 0 %}amount--out{% else %}amount--in{% endif %}">
                    {{ tx.amount_int|number_format(0, ',', ' ') }} {{ tx.currency }}
                </span>
                {% if tx.counter_account_name %}
                    <span class="pairing-tx-from" title="Protiúčet">{{ tx.counter_account_name }}</span>
                {% endif %}
                {% if tx.message %}
                    <span class="pairing-tx-msg" title="Zpráva">{{ tx.message }}</span>
                {% endif %}
                {% if tx.variable_symbol %}
                    <span class="pairing-tx-vs" title="Variabilní symbol">VS: {{ tx.variable_symbol }}</span>
                {% endif %}
            </div>
            <div class="pairing-tx-status">
                {% if tx.completed %}
                    <span class="pairing-badge pairing-badge--done">Vyřízeno {{ tx.completed|date('j.n.Y H:i') }}</span>
                {% else %}
                    <span class="pairing-badge pairing-badge--open">Nevyřízeno</span>
                {% endif %}
            </div>
        </div>
        {% if not tx.completed %}
        <div class="pairing-footer">
            <form method="POST" action="/admin/pairing/complete-transaction"
                  onsubmit="return confirm('Označit transakci jako vyřízenou?')">
                <input type="hidden" name="_csrf" value="{{ csrf }}">
                <input type="hidden" name="transaction_id" value="{{ tx.id }}">
                <input type="hidden" name="back" value="{{ back_url }}#transaction-{{ tx.id }}">
                <button type="submit" class="btn btn--success">Označit transakci jako vyřízenou</button>
            </form>
        </div>
        {% endif %}
    </div>
    {% endfor %}
{% endif %}

<style>
.pairing-card {
    border: 1px solid var(--color-border, #ddd);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    background: #fff;
    overflow: hidden;
}
.pairing-card--done { opacity: 0.6; }
.pairing-tx-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    background: #f5f7fa;
    border-bottom: 1px solid var(--color-border, #ddd);
    flex-wrap: wrap;
}
.pairing-tx-meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    font-size: 0.93rem;
}
.pairing-tx-date   { color: var(--color-muted, #666); }
.pairing-tx-amount { font-weight: 700; font-size: 1.05rem; }
.pairing-tx-from   { color: var(--color-muted, #555); }
.pairing-tx-msg    { font-style: italic; color: var(--color-muted, #777); max-width: 260px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pairing-tx-vs     { font-family: monospace; background: #eef; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.85rem; }
.pairing-badge {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
}
.pairing-badge--done { background: #e6f5ec; color: #27ae60; }
.pairing-badge--open { background: #fef9e7; color: #d68910; }
.pairing-badge--hero { background: #fff3cd; color: #856404; }
.pairing-section { padding: 0.75rem 1.25rem 0.75rem; }
.pairing-empty {
    padding: 0.75rem 1.25rem;
    font-size: 0.9rem;
    color: var(--color-muted, #999);
}
.pairing-footer {
    padding: 0.75rem 1.25rem 1rem;
    border-top: 1px solid var(--color-border, #eee);
    margin-top: 0.75rem;
}
.pairing-status-form {
    display: flex;
    align-items: center;
    gap: 0.4rem;
}
.pairing-select {
    padding: 0.25rem 0.4rem;
    border: 1px solid var(--color-border, #ccc);
    border-radius: 4px;
    font-size: 0.85rem;
}
.pairing-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
}
.pairing-status--pending    { background: #fef9e7; color: #d68910; }
.pairing-status--paid       { background: #e6f5ec; color: #27ae60; }
.pairing-status--approved   { background: #e8f4fd; color: #2980b9; }
.pairing-status--upgradable { background: #f0e6ff; color: #7d3c98; }
.pairing-status--notpaid    { background: #fdecea; color: #c0392b; }
.pairing-status--cancelled  { background: #f2f2f2; color: #888; }
.pairing-status--refunded   { background: #f5f0ff; color: #8e44ad; }
.pairing-row--cancelled td  { opacity: 0.5; }
.pairing-queue { text-align: center; font-weight: 600; color: var(--color-muted, #666); }
.amount--in  { color: #27ae60; }
.amount--out { color: #c0392b; }
.type-badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 4px; font-size: 0.78rem; font-weight: 700; }
.type-badge--ticket { background: #e8f4fd; color: #2980b9; }
