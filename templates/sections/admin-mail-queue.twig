<div class="card">
    <div class="card__body">
        <div class="card__header">
            <h3>Fronta e-mailů <small>(posledních 200)</small></h3>
        </div>
        {% if mails is empty %}
            <p>Fronta je prázdná.</p>
        {% else %}
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Komu</th>
                        <th>Předmět</th>
                        <th>Šablona</th>
                        <th>Stav</th>
                        <th>Zařazeno</th>
                        <th>Odesláno</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for m in mails %}
                        <tr>
                            <td>{{ m.id }}</td>
                            <td>{{ m.to_email }}</td>
                            <td>{{ m.subject }}</td>
                            <td>{{ m.template ?? '–' }}</td>
                            <td><span class="badge badge--{{ m.status }}">{{ m.status }}</span></td>
                            <td>{{ m.queued_at }}</td>
                            <td>{{ m.sent_at ?? '–' }}</td>
                            <td>
                                <button class="btn btn--sm"
                                        onclick="openMailPreview({{ m.id }}, {{ m.subject|json_encode }})">
                                    Náhled
                                </button>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

{# Preview modal #}
<div id="mail-preview-modal" class="modal hidden">
    <div class="modal-content" style="width:90%; max-width:900px;">
        <div class="modal-header">
            <h3 id="mail-preview-title" style="font-size:1rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></h3>
            <button class="modal-close" onclick="closeMailPreview()">&times;</button>
        </div>
        <iframe id="mail-preview-frame"
                src=""
                style="width:100%; height:70vh; border:none; display:block;"></iframe>
    </div>
</div>

<script>
function openMailPreview(id, subject) {
    document.getElementById('mail-preview-title').textContent = subject;
    document.getElementById('mail-preview-frame').src = '/admin/mail-queue/' + id + '/preview';
    document.getElementById('mail-preview-modal').classList.remove('hidden');
}
function closeMailPreview() {
    document.getElementById('mail-preview-modal').classList.add('hidden');
    document.getElementById('mail-preview-frame').src = '';
}
document.getElementById('mail-preview-modal').addEventListener('click', function(e) {
    if (e.target === this) closeMailPreview();
});
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMailPreview();
});
</script>
