<!-- Homepage -->
<div class="hero">
    <div class="container">
        <div class="hero-content">
            <h1>Improtřesk 2026</h1>
            <p class="hero-subtitle"><img src="/sysimg/logo.png" alt="Logo festivalu" width=400></p>
            <p class="hero-subtitle">Mezinárodní festival improvizačního divadla</p>
            <div class="hero-info">
                <div class="info-item">
                    <strong>Kdy:</strong> 7.-10. květen 2026
                   
                </div>
                <div class="info-item">
                    <strong>Kde:</strong>  Praha
                </div>
                <div class="info-item">
                    <strong>Vstupné:</strong> ???? Kč
                </div>
                <div class="info-item">
                    <a href="https://www.facebook.com/events/1919076465165143/" >Facebook</a> 
                </div>

                
            </div>
            <a href="/register" class="btn btn--primary btn--lg">Zaregistruj se</a>
        </div>
    </div>
</div>

{% if registration_start and registration_start|date('U') > "now"|date('U') %}
<div class="countdown-section">
    <div class="container">
        <p class="countdown-label">Registrace možná začínají {{ registration_start|date('j. n. Y') }} v {{ registration_start|date('H:i') }}</p>
        <div class="countdown" id="countdown" data-target="{{ registration_start }}">
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-days">--</span>
                <span class="countdown-name">dní</span>
            </div>
            <div class="countdown-sep">:</div>
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-hours">--</span>
                <span class="countdown-name">hodin</span>
            </div>
            <div class="countdown-sep">:</div>
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-minutes">--</span>
                <span class="countdown-name">minut</span>
            </div>
            <div class="countdown-sep">:</div>
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-seconds">--</span>
                <span class="countdown-name">sekund</span>
            </div>
        </div>
    </div>
</div>
{% endif %}
