<!-- Homepage -->
<div class="hero">
    <div class="container">
        <div class="hero-content">
            <h1><span style="color:#a85f31ff">I</span><span style="color:#ecb737ff">M</span><span style="color:#d45842ff">P</span><span style="color:#47a8afff">R</span><span style="color:#98a239ff">O</span><span style="color:#3c66a6ff">T</span><span style="color:#7e4994ff">Ř</span><span style="color:#a44c7dff">E</span><span style="color:#768f89ff">S</span><span style="color:#7e8845ff">K</span></h1>
            <p class="hero-subtitle">Festival improvizace</p>
            <div class="hero-info">
                <div class="info-item">
                    <strong>Kdy:</strong> 7.-10. května 2026                   
                </div>
                <div class="info-item">
                    <strong>Kde:</strong>  Praha
                </div>                
                <div class="info-item" style="border:thin solid #1877F2;border-radius:5px;">
                    <a href="https://www.facebook.com/events/1919076465165143/" >Facebooková událost</a> 
                </div>

            </div>
            {% if user %}
            <a href="/dashboard" class="btn btn--primary btn--lg">Můj účet</a>
            {% else %}
            <a href="/register" class="btn btn--primary btn--lg">Zaregistruj se</a>
            {% endif     %}
        </div>
    </div>
</div>

{% if registration_start and registration_start|date('U') > "now"|date('U') %}
<div class="countdown-section">
    <div class="container">
        <p class="countdown-label">Výběry workshopů se spouští {{ registration_start|date('j. n. Y') }} v {{ registration_start|date('H:i') }}</p>
        <div class="countdown" id="countdown" data-target="{{ registration_start }}">
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-days">--</span>
                <span class="countdown-name">dní</span>
            </div>
            <div class="countdown-sep">:</div>
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-hours">--</span>
                <span class="countdown-name">hodin</span>
            </div>
            <div class="countdown-sep">:</div>
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-minutes">--</span>
                <span class="countdown-name">minut</span>
            </div>
            <div class="countdown-sep">:</div>
            <div class="countdown-unit">
                <span class="countdown-value" id="cd-seconds">--</span>
                <span class="countdown-name">sekund</span>
            </div>
        </div>
    </div>
</div>
{% else %}
<div class="countdown-section">
    <div class="container">
        <h2>Přihlašování na workshopy běží!</h2>
    </div>
</div>
{% endif %}
