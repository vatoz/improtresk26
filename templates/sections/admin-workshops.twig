<div class="card">
    <div class="card__body">
        <h3>Správa workshopů</h3>
        {% if workshops is empty %}
            <p>Žádné workshopy.</p>
        {% else %}
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Lektor</th>
                        <th>Datum</th>
                        <th>Kapacita</th>
                        <th>Přihlášeno</th>
                        <th>Zaplaceno</th>
                        <th>Aktivní</th>
                        <th>Poznámka k mailu</th>
                    </tr>
                </thead>
                <tbody>
                    {% for w in workshops %}
                        <tr>
                            <td>{{ w.name }}</td>
                            <td>{{ w.instructor ?? '–' }}</td>
                            <td>{{ w.start_datetime ?? '–' }}</td>
                            <td>{{ w.capacity }}</td>
                            <td>{{ w.registered_count }}</td>
                            <td>{{ w.paid_count }}</td>
                            <td>{{ w.is_active ? 'Ano' : 'Ne' }}</td>
                            <td>
                                <form method="post" action="/admin/workshops/{{ w.id }}/mailnote" class="mailnote-form">
                                    <textarea name="mailnote" rows="2" class="mailnote-input">{{ w.mailnote ?? '' }}</textarea>
                                    <button type="submit" class="btn btn--small">Uložit</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

<style>
.mailnote-form { display: flex; flex-direction: column; gap: 4px; }
.mailnote-input { width: 100%; min-width: 180px; font-size: 0.85rem; padding: 4px; resize: vertical; }
.btn--small { align-self: flex-start; padding: 2px 10px; font-size: 0.8rem; }
</style>
