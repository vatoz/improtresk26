{% extends 'base.twig' %}

{% block title %}Průvodce registrací – Platba – Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">

        {# Progress bar #}
        <div class="wizard-progress">
            <div class="wizard-step wizard-step--done">
                <span class="wizard-step__num">✓</span>
                <span class="wizard-step__label">Workshopy</span>
            </div>
            <div class="wizard-progress__line wizard-progress__line--done"></div>
            <div class="wizard-step wizard-step--done">
                <span class="wizard-step__num">✓</span>
                <span class="wizard-step__label">Vstupenky</span>
            </div>
            <div class="wizard-progress__line wizard-progress__line--done"></div>
            <div class="wizard-step wizard-step--done">
                <span class="wizard-step__num">✓</span>
                <span class="wizard-step__label">Merch</span>
            </div>
            <div class="wizard-progress__line wizard-progress__line--done"></div>
            <div class="wizard-step wizard-step--active">
                <span class="wizard-step__num">4</span>
                <span class="wizard-step__label">Platba</span>
            </div>
        </div>

        <h1>Krok 4: Platební údaje</h1>

        <div class="wizard-payment-grid">

            {# Order summary #}
            <div class="card">
                <div class="card__header">
                    <h2 class="wizard-section-title">Přehled objednávky</h2>
                </div>
                <div class="card__body">

                    {% if registrations is not empty %}
                        <h3 class="wizard-subsection">Workshopy</h3>
                        <table class="wizard-summary-table">
                            {% for r in registrations %}
                            <tr>
                                <td>{{ r.workshop_name }}</td>
                                <td class="wizard-summary-status">
                                    <span class="wizard-status wizard-status--{{ r.payment_status }}">
                                        {% if r.payment_status == 'pending' %}čeká na platbu
                                        {% elseif r.payment_status == 'approved' %}schváleno
                                        {% else %}{{ r.payment_status }}{% endif %}
                                    </span>
                                </td>
                                <td class="wizard-summary-price">{{ r.price|number_format(0, ',', ' ') }} Kč</td>
                            </tr>
                            {% endfor %}
                        </table>
                    {% endif %}

                    {% if purchases is not empty %}
                        <h3 class="wizard-subsection">Vstupenky a merch</h3>
                        <table class="wizard-summary-table">
                            {% for p in purchases %}
                            <tr>
                                <td>
                                    {{ p.item_name }}
                                    {% if p.quantity > 1 %}&nbsp;×&nbsp;{{ p.quantity }}{% endif %}
                                </td>
                                <td class="wizard-summary-status">
                                    <span class="wizard-status wizard-status--{{ p.payment_status }}">
                                        {% if p.payment_status == 'pending' %}čeká na platbu
                                        {% elseif p.payment_status == 'approved' %}schváleno
                                        {% else %}{{ p.payment_status }}{% endif %}
                                    </span>
                                </td>
                                <td class="wizard-summary-price">{{ (p.item_price * p.quantity)|number_format(0, ',', ' ') }} Kč</td>
                            </tr>
                            {% endfor %}
                        </table>
                    {% endif %}

                    <div class="wizard-total-row">
                        <span>Celkem k úhradě</span>
                        <strong class="wizard-total-amount">{{ total|number_format(0, ',', ' ') }} Kč</strong>
                    </div>
                </div>
            </div>

            {# Payment details #}
            <div class="card">
                <div class="card__header">
                    <h2 class="wizard-section-title">Jak zaplatit</h2>
                </div>
                <div class="card__body">
                    <div class="wizard-qr-wrap">
                        <img src="{{ qr }}" alt="QR kód pro platbu" class="wizard-qr-img">
                        <p class="wizard-qr-caption">Naskenujte QR kód v mobilním bankovnictví</p>
                    </div>

                    <div class="wizard-bank-details">
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Číslo účtu / IBAN</span>
                            <span class="wizard-bank-value">{{ payment.account_number }}</span>
                        </div>
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Variabilní symbol</span>
                            <span class="wizard-bank-value">{{ payment.variable_symbol }}</span>
                        </div>
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Částka</span>
                            <span class="wizard-bank-value">{{ payment.amount|number_format(0, ',', ' ') }} {{ payment.currency }}</span>
                        </div>
                        {% if payment.message %}
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Zpráva pro příjemce</span>
                            <span class="wizard-bank-value">{{ payment.message }}</span>
                        </div>
                        {% endif %}
                    </div>

                    <p class="wizard-payment-note">
                        Po připsání platby vás budeme informovat e-mailem. Registrace jsou platné po úhradě.
                    </p>
                </div>
            </div>

        </div>

        <div class="wizard-nav wizard-nav--end">
            <a href="/dashboard" class="btn btn--primary">Přejít na můj přehled</a>
        </div>

    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.wizard-progress {
    display: flex;
    align-items: center;
    margin-bottom: 2rem;
}
.wizard-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    min-width: 60px;
}
.wizard-step__num {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-border, #e0e0e0);
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
}
.wizard-step--active .wizard-step__num {
    background: var(--color-primary, #c0392b);
    color: #fff;
}
.wizard-step--done .wizard-step__num {
    background: #27ae60;
    color: #fff;
}
.wizard-step__label {
    font-size: 0.75rem;
    color: var(--color-muted, #777);
    white-space: nowrap;
}
.wizard-step--active .wizard-step__label {
    color: var(--color-primary, #c0392b);
    font-weight: 600;
}
.wizard-progress__line {
    flex: 1;
    height: 2px;
    background: var(--color-border, #e0e0e0);
    margin-bottom: 1.2rem;
}
.wizard-progress__line--done {
    background: #27ae60;
}
.wizard-payment-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}
@media (max-width: 700px) {
    .wizard-payment-grid { grid-template-columns: 1fr; }
}
.wizard-section-title {
    margin: 0;
    font-size: 1.1rem;
}
.wizard-subsection {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-muted, #666);
    margin: 1rem 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}
.wizard-summary-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
}
.wizard-summary-table td {
    padding: 0.35rem 0.25rem;
    vertical-align: middle;
}
.wizard-summary-status {
    text-align: center;
}
.wizard-summary-price {
    text-align: right;
    white-space: nowrap;
    font-weight: 600;
}
.wizard-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
}
.wizard-status--pending  { background: #fff3cd; color: #856404; }
.wizard-status--approved { background: #d1ecf1; color: #0c5460; }
.wizard-status--paid     { background: #d4edda; color: #155724; }
.wizard-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 2px solid var(--color-border, #e0e0e0);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    font-size: 1rem;
}
.wizard-total-amount {
    font-size: 1.25rem;
    color: var(--color-primary, #c0392b);
}
.wizard-qr-wrap {
    text-align: center;
    margin-bottom: 1.25rem;
}
.wizard-qr-img {
    max-width: 180px;
    height: auto;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 6px;
    padding: 0.5rem;
}
.wizard-qr-caption {
    margin: 0.4rem 0 0;
    font-size: 0.82rem;
    color: var(--color-muted, #777);
}
.wizard-bank-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
}
.wizard-bank-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.95rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--color-border, #f0f0f0);
}
.wizard-bank-label {
    color: var(--color-muted, #666);
    white-space: nowrap;
}
.wizard-bank-value {
    font-weight: 600;
    word-break: break-all;
    text-align: right;
}
.wizard-payment-note {
    font-size: 0.85rem;
    color: var(--color-muted, #666);
    background: #f8f9fa;
    border-radius: 6px;
    padding: 0.75rem;
    margin: 0;
}
.wizard-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
    gap: 1rem;
}
.wizard-nav--end {
    justify-content: flex-end;
}
</style>
{% endblock %}
