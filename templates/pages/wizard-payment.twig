{% extends 'base.twig' %}

{% block title %}Průvodce registrací – Platba – Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">

        {{ include('inlines/wizard-progress.twig') }}

        <h1>Krok 4: Platební údaje</h1>

        <div class="wizard-payment-grid">

            {# Order summary #}
            <div class="card">
                <div class="card__header">
                    <h2 class="wizard-section-title">Přehled objednávky</h2>
                </div>
                <div class="card__body">

                    {% if registrations is not empty %}
                        <h3 class="wizard-subsection">Workshopy</h3>
                        <table class="wizard-summary-table">
                            {% for r in registrations %}
                            <tr{% if r.likely_no_spot is defined and r.likely_no_spot %} class="wps-row--nospot"{% endif %}>
                                <td>
                                    {{ r.workshop_name }}
                                    {% if r.queue_position is defined %}
                                        <span class="wps-queue">{{ r.queue_position + 1 }}. místo na čekací listině</span>
                                    {% endif %}
                                    {% if r.likely_no_spot is defined and r.likely_no_spot %}
                                        <div class="wps-nospot-warn">
                                            ⚠ Na workshop se pravděpodobně nedostanete – do platby nezahrnuto.
                                        </div>
                                    {% endif %}
                                </td>
                                <td class="wizard-summary-status">
                                    <span class="wizard-status wizard-status--{{ r.payment_status }}">
                                        {% if r.payment_status == 'pending' %}čeká 
                                        {% elseif r.payment_status == 'approved' %}schváleno
                                        {% elseif r.payment_status == 'timeblock' %}Překryv, do platby nezahrnuto
                                        {% else %}{{ r.payment_status }}{% endif %}
                                    </span>
                                </td>
                                <td>{{ r.timeslot_name }}</td>
                                <td class="wizard-summary-price">
                                    {% if r.price > 0 %}{{ r.price|number_format(0, ',', ' ') }} Kč
                                    {% elseif r.gray_price %}
                                   <!-- <span style="color: #666">{{ r.gray_price|number_format(0, ',', ' ') }} Kč</span>-->

                                    {% endif %}
                                    

                                </td>
                            </tr>
                            {% endfor %}
                        </table>
                    {% endif %}

                    {% if purchases is not empty %}
                        <h3 class="wizard-subsection">Vstupenky a merch</h3>
                        <table class="wizard-summary-table">
                            {% for p in purchases %}
                            <tr>
                                <td>
                                    {{ p.item_name }}
                                    {% if p.quantity > 1 %}&nbsp;×&nbsp;{{ p.quantity }}{% endif %}
                                </td>
                                <td class="wizard-summary-status">
                                    <span class="wizard-status wizard-status--{{ p.payment_status }}">
                                        {% if p.payment_status == 'pending' %}čeká
                                        {% elseif p.payment_status == 'approved' %}schváleno
                                        {% else %}{{ p.payment_status }}{% endif %}
                                    </span>
                                </td>
                                <td class="wizard-summary-price">{{ (p.item_price * p.quantity)|number_format(0, ',', ' ') }} Kč</td>
                            </tr>
                            {% endfor %}
                        </table>
                    {% endif %}

                    <div class="wizard-total-row">
                        <span>Celkem k úhradě</span>
                        <strong class="wizard-total-amount">{{ total|number_format(0, ',', ' ') }} Kč</strong>
                    </div>

                    {% if user.hero is defined and user.hero > 0 %}
                    <div class="hero-discount-box">
                        <strong>Sleva za tebo garantovaný workshop</strong>
                        <p>Pro workshop, který garantuješ, si od výše uvedené částky odečti:</p>
                        <table class="hero-discount-table">
                            <tr>
                                <td>Dvoudenní workshop</td>
                                <td>−&nbsp;1&nbsp;000&nbsp;Kč</td>
                            </tr>
                            <tr>
                                <td>Jednodenní workshop</td>
                                <td>−&nbsp;500&nbsp;Kč</td>
                            </tr>
                            <tr>
                                <td>Půldenní workshop</td>
                                <td>−&nbsp;300&nbsp;Kč</td>
                            </tr>
                        </table>
                        <p class="hero-discount-note">Slevu uplatni přímo v platbě – pošli o příslušnou částku méně. 
                
                        Při párování plateb na to pamatuju.  Pokud s tím budeš mít trable, klidně mi brnkni.<br>
                        
                        Vašek 604 209 354</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Payment details #}
            <div class="card">
                <div class="card__header">
                    <h2 class="wizard-section-title">Jak zaplatit</h2>
                </div>
                <div class="card__body">
                    <div class="wizard-qr-wrap">
                        <img src="{{ qr }}" alt="QR kód pro platbu" class="wizard-qr-img">
                        <p class="wizard-qr-caption">Naskenujte QR kód v mobilním bankovnictví</p>
                    </div>

                    <div class="wizard-bank-details">
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Číslo účtu / IBAN</span>
                            <span class="wizard-bank-value">{{ payment.account_number }}</span>
                        </div>
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Variabilní symbol</span>
                            <span class="wizard-bank-value">{{ payment.variable_symbol }}</span>
                        </div>
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Částka</span>
                            <span class="wizard-bank-value">{{ payment.amount|number_format(0, ',', ' ') }} {{ payment.currency }}</span>
                        </div>
                        {% if payment.message %}
                        <div class="wizard-bank-row">
                            <span class="wizard-bank-label">Zpráva pro příjemce</span>
                            <span class="wizard-bank-value">{{ payment.message }}</span>
                        </div>
                        {% endif %}
                    </div>

                    <p class="wizard-payment-note">
                        Po připsání platby vás budeme informovat e-mailem. Registrace jsou platné po úhradě.
                        Na úhradu máte pět dní.
                    </p>
                </div>
            </div>

        </div>
        
        {{ include('inlines/wizard-nav.twig') }}

    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.wizard-payment-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}
@media (max-width: 700px) {
    .wizard-payment-grid { grid-template-columns: 1fr; }
}
.wizard-section-title { margin: 0; font-size: 1.1rem; }
.wizard-subsection {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-muted, #666);
    margin: 1rem 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}
.wizard-summary-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
.wizard-summary-table td { padding: 0.35rem 0.25rem; vertical-align: middle; }
.wizard-summary-status { text-align: center; }
.wizard-summary-price  { text-align: right; white-space: nowrap; font-weight: 600; }
.wizard-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
}
.wizard-status--pending  { background: #fff3cd; color: #856404; }
.wizard-status--approved { background: #d1ecf1; color: #0c5460; }
.wizard-status--paid     { background: #d4edda; color: #155724; }
.wizard-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 2px solid var(--color-border, #e0e0e0);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    font-size: 1rem;
}
.wizard-total-amount { font-size: 1.25rem; color: var(--color-primary, #c0392b); }
.wizard-qr-wrap    { text-align: center; margin-bottom: 1.25rem; }
.wizard-qr-img     { max-width: 180px; height: auto; border: 1px solid var(--color-border, #e0e0e0); border-radius: 6px; padding: 0.5rem; }
.wizard-qr-caption { margin: 0.4rem 0 0; font-size: 0.82rem; color: var(--color-muted, #777); }
.wizard-bank-details { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
.wizard-bank-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.95rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--color-border, #f0f0f0);
}
.wizard-bank-label { color: var(--color-muted, #666); white-space: nowrap; }
.wizard-bank-value { font-weight: 600; word-break: break-all; text-align: right; }
.wps-queue {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    background: #e8f4fd;
    color: #1a6fa8;
    margin-left: 0.35rem;
    vertical-align: middle;
}
.wps-nospot-warn {
    font-size: 0.8rem;
    color: #856404;
    margin-top: 0.2rem;
}
.wps-row--nospot td {
    opacity: 0.65;
}
.wizard-payment-note {
    font-size: 0.85rem;
    color: var(--color-muted, #666);
    background: #f8f9fa;
    border-radius: 6px;
    padding: 0.75rem;
    margin: 0;
}
.hero-discount-box {
    margin-top: 1rem;
    padding: .75rem 1rem;
    background: #fffbea;
    border-left: 4px solid #f0c040;
    border-radius: 0 6px 6px 0;
    font-size: .9rem;
}
.hero-discount-box strong { display: block; margin-bottom: .35rem; }
.hero-discount-box p { margin: .35rem 0; color: #555; }
.hero-discount-table {
    width: 100%;
    border-collapse: collapse;
    margin: .5rem 0;
}
.hero-discount-table td {
    padding: .25rem .25rem;
    border-bottom: 1px solid #f0e0a0;
}
.hero-discount-table td:last-child {
    text-align: right;
    font-weight: 600;
    white-space: nowrap;
    color: #b8860b;
}
.hero-discount-note {
    font-size: .8rem;
    color: #888;
    margin-top: .4rem !important;
}
</style>
{% endblock %}
