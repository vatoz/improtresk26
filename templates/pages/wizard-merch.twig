{% extends 'base.twig' %}

{% block title %}Průvodce registrací – Merch – Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">

        {{ include('inlines/wizard-progress.twig') }}

        <h1>Krok 3: Merch</h1>
        <p class="wizard-intro">Vyberte merch, který si přejete objednat. Krok můžete přeskočit.</p>

        {% if error %}
            <div class="alert alert-error">{{ error }}</div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        <form method="POST" action="/wizard/merch">
            <input type="hidden" name="_csrf" value="{{ csrf }}">

            {% if items is empty %}
                <div class="card">
                    <div class="card__body">
                        <p>Momentálně není k dispozici žádný merch.</p>
                    </div>
                </div>
            {% else %}
                <div class="shop-grid">
                    {% for item in items %}
                        {% set alreadyOrdered = item.id in user_purchased_ids %}
                        <div class="shop-card{% if alreadyOrdered %} shop-card--ordered{% endif %}">
                            <div class="shop-card__body">
                                <h3 class="shop-card__name">{{ item.name }}</h3>

                                {% if item.description %}
                                    <p class="shop-card__desc">{{ item.description }}</p>
                                {% endif %}

                                <div class="shop-card__footer">
                                    <span class="shop-card__price">{{ item.price|number_format(0, ',', ' ') }} Kč</span>
                                    <label class="wizard-checkbox-label">
                                        <input type="checkbox" name="merch_ids[]" value="{{ item.id }}">
                                        {% if alreadyOrdered %}Přidat další{% else %}Objednat{% endif %}
                                    </label>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {{ include('inlines/wizard-nav.twig') }}
        </form>

    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.wizard-intro { margin-bottom: 1.5rem; color: var(--color-muted, #555); }
.shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
}
.shop-card {
    background: var(--color-card-bg, #fff);
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    overflow: hidden;
}
.shop-card--ordered { border-color: #27ae60; background: #f7fdf9; }
.shop-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}
.shop-card__name  { margin: 0; font-size: 1.1rem; }
.shop-card__desc  { margin: 0; font-size: 0.9rem; color: var(--color-muted, #666); }
.shop-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
}
.shop-card__price {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary, #c0392b);
}
.wizard-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary, #c0392b);
}
</style>
{% endblock %}
