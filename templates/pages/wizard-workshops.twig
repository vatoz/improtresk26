{% extends 'base.twig' %}

{% block title %}Průvodce registrací – Workshopy – Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">

        {{ include('inlines/wizard-progress.twig') }}

         <h1 >{{ timeslot.name }}</h1>

         {{ include('inlines/wizard-info.twig') }}
        

        {% if error %}
            <div class="alert alert-error">{{ error }}</div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        {% if workshops is empty %}
            <div class="card wts-empty-card">
                <div class="card__body">
                    <p>V tomto bloku nejsou dostupné žádné workshopy.</p>
                </div>
            </div>
        {% else %}
            <div class="wts-grid">
                {% for workshop in workshops %}
                    <label class="wts-card{% if workshop.alreadyRegistered %} bg4{% endif %}" for="ws-{{ workshop.id }}">
                        <form method="POST" action="/wizard/workshops">
                            <input type="hidden" name="_csrf" value="{{ csrf }}">
                            <input type="hidden" name="slot"  value="{{ timeslot.code }}">
                            {% if workshop.alreadyRegistered %}
                                {% if workshop.alreadyRegistered != 'paid' %}
                                    <input type="hidden" name="cancel_workshop_id" value="{{ workshop.id }}">
                                    <button type="submit" class="btn btn--primary btn--sm" style="float:right;">
                                        Zrušit registraci
                                    </button>
                                    {% if workshop.queue_position is defined %}
                                        <span class="wts-queue">
                                            {{ workshop.queue_position + 1 }}. místo na čekací listině<br>
                                            {% if workshop.queue_position  +1 > workshop.capacity %}
                                                Na čekací listině je dost lidí před vámi. 
                                                Doporučujeme se zařadit na čekací listinu u dalšího workshopu.
                                            {% endif %}        
                                        </span>
                                    {% endif %}
                                {% else %}
                                    Zaplaceno!
                                {% endif %}
                            {% else %}
                                <input type="hidden" name="workshop_id" value="{{ workshop.id }}">
                                <button type="submit" class="btn btn--primary btn--sm">
                                    Registrovat se na čekací listinu
                                </button>
                            {% endif %}
                        </form>

                        <div class="wts-card__inner">
                            <div class="wts-card__body">
                                {{ include('inlines/workshop.twig') }}
                            </div>
                        </div>
                    </label>
                {% endfor %}
            </div>
        {% endif %}


        {{ include('inlines/wizard-nav.twig') }}


    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ── Timeslot header ─────────────────────────────── */
.wts-header { margin-bottom: 0.75rem; }
.wts-meta {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary, #c0392b);
    margin-bottom: 0.3rem;
}
.wts-title  { margin: 0 0 0.4rem; font-size: 1.6rem; }
.wts-hint   { margin: 0; font-size: 0.9rem; color: var(--color-muted, #666); }

/* ── Timeslot progress dots ──────────────────────── */
.wts-dots {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}
.wts-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border, #ddd);
    flex-shrink: 0;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.15s;
}
.wts-dot:hover    { opacity: 0.7; }
.wts-dot--done    { background: #27ae60; }
.wts-dot--active  { background: var(--color-primary, #c0392b); }

/* ── Workshop toggle cards ───────────────────────── */
.wts-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
}
.wts-card {
    display: block;
    cursor: pointer;
    border: 2px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
    background: #fff;
    user-select: none;
}
.wts-card:not(:has(.wts-checkbox:disabled)):hover { border-color: #bbb; }
.wts-checkbox { position: absolute; opacity: 0; width: 0; height: 0; }
.wts-card__inner {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
}
.wts-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
}
.wts-card__name { font-size: 1rem; }
.wts-card__meta { font-size: 0.82rem; color: var(--color-muted, #777); }
.wts-badge {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
}
.wts-badge--full { background: #fdecea; color: #c0392b; }
.wts-empty-card  { margin-bottom: 1.5rem; }
.wts-queue {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: #e8f4fd;
    color: #1a6fa8;
    margin-left: 0.4rem;
}
</style>
{% endblock %}
