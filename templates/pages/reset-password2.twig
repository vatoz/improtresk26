{% extends 'base.twig' %}

{% block title %}Obnova hesla - Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">
        <div class="content" style="max-width: 500px; margin: 0 auto;">
            <div class="header">
                <h3>Obnova hesla</h3>
            </div>

            {% if error %}
                <div class="alert alert-error">
                    {{ error }}
                </div>
                <div class="form-actions">
                    <a href="/reset-password" class="btn btn--outline">Zkusit znovu</a>
                    <a href="/" class="btn btn--primary">Zpět na hlavní stránku</a>
                </div>
            {% elseif token %}
                <form method="POST" action="/reset-password">
                    <input type="hidden" name="token" value="{{ token }}">

                    <div class="form-group">
                        <label class="form-label">Email:</label>
                        <input type="email" value="{{ email }}" class="form-control" disabled>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Nové heslo:</label>
                        <input type="password" name="password" class="form-control" required minlength="6">
                        <small>Minimálně 6 znaků</small>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Potvrdit heslo:</label>
                        <input type="password" name="password_confirm" class="form-control" required minlength="6">
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn--primary">Změnit heslo</button>
                    </div>
                </form>
            {% else %}
                <p>Zadej svůj přihlašovací e-mail a zašleme ti odkaz pro obnovu hesla.</p>

                <div id="reset-result" style="display:none;" class="alert"></div>

                <form id="reset-request-form">
                    <div class="form-group">
                        <label class="form-label">E-mail:</label>
                        <input type="email" name="email" class="form-control" required autofocus
                               placeholder="tvuj@email.cz">
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn--primary">Odeslat odkaz</button>
                        <a href="/login" class="btn btn--outline">Zpět na přihlášení</a>
                    </div>
                </form>

                <script>
                document.getElementById('reset-request-form').addEventListener('submit', async function (e) {
                    e.preventDefault();
                    const email  = this.querySelector('[name="email"]').value;
                    const btn    = this.querySelector('button[type="submit"]');
                    const result = document.getElementById('reset-result');

                    btn.disabled = true;
                    result.style.display = 'none';

                    try {
                        const res  = await fetch('/request-password-reset', {
                            method:  'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body:    JSON.stringify({ email }),
                        });
                        const data = await res.json();

                        result.textContent   = data.message;
                        result.className     = 'alert ' + (data.success ? 'alert-success' : 'alert-error');
                        result.style.display = 'block';

                        if (data.success) {
                            this.style.display = 'none';
                        }
                    } catch (_) {
                        result.textContent   = 'Chyba při odesílání. Zkus to prosím znovu.';
                        result.className     = 'alert alert-error';
                        result.style.display = 'block';
                    } finally {
                        btn.disabled = false;
                    }
                });
                </script>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
