{% extends 'base.twig' %}

{% block title %}Průvodce registrací – Vstupenky – Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">

        {{ include('inlines/wizard-progress.twig') }}

        <h1>Krok 2: Vstupenky</h1>
        <p class="wizard-intro">Vyberte vstupenky, které si přejete zakoupit.
         Pokud máte registraci na celodenní či vícedenní workshop, vstupenky na večerní/odpolední program nepotřebujete.</p>

        {% if error %}
            <div class="alert alert-error">{{ error }}</div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success">{{ success }}</div>
        {% endif %}

        {% if tickets is empty %}
            <div class="card">
                <div class="card__body">
                    <p>Momentálně nejsou k dispozici žádné vstupenky.</p>
                </div>
            </div>
        {% else %}
            <div class="shop-grid">
                {% for ticket in tickets %}
                    {% set alreadyOrdered = ticket.id in user_purchased_ids %}
                    <div class="shop-card{% if alreadyOrdered %} shop-card--ordered{% endif %}">
                        <div class="shop-card__body">
                            <h3 class="shop-card__name">{{ ticket.name }}</h3>

                            {% if ticket.description %}
                                <p class="shop-card__desc">{{ ticket.description }}</p>
                            {% endif %}

                            <div class="shop-card__meta">
                                {% if ticket.date %}
                                    <span>{{ ticket.date|date('j.n.Y') }}{% if ticket.time %} {{ ticket.time|slice(0,5) }}{% endif %}</span>
                                {% endif %}
                            </div>

                            <div class="shop-card__footer">
                                <span class="shop-card__price">{{ ticket.price|number_format(0, ',', ' ') }} Kč</span>

                                {% if alreadyOrdered %}
                                    <span class="wizard-badge wizard-badge--ordered">✓ Přidáno</span>
                                    <form method="POST" action="/wizard/tickets">
                                        <input type="hidden" name="_csrf" value="{{ csrf }}">
                                        <input type="hidden" name="cancel_ticket_id" value="{{ ticket.id }}">
                                        <button type="submit" class="btn btn--outline btn--sm">Odebrat</button>
                                    </form>
                                {% else %}
                                    <form method="POST" action="/wizard/tickets">
                                        <input type="hidden" name="_csrf" value="{{ csrf }}">
                                        <input type="hidden" name="ticket_id" value="{{ ticket.id }}">
                                        <button type="submit" class="btn btn--primary btn--sm">Přidat</button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {{ include('inlines/wizard-nav.twig') }}

    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.wizard-intro { margin-bottom: 1.5rem; color: var(--color-muted, #555); }
.shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
}
.shop-card {
    background: var(--color-card-bg, #fff);
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    overflow: hidden;
}
.shop-card--ordered { border-color: #27ae60; background: #f7fdf9; }
.shop-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}
.shop-card__name  { margin: 0; font-size: 1.1rem; }
.shop-card__desc  { margin: 0; font-size: 0.9rem; color: var(--color-muted, #666); }
.shop-card__meta  { font-size: 0.85rem; color: var(--color-muted, #666); }
.shop-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
}
.shop-card__price {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary, #c0392b);
}
.wizard-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
}
.wizard-badge--ordered { background: #e6f5ec; color: #27ae60; }
</style>
{% endblock %}
