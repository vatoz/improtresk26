{% extends 'base.twig' %}

{% block title %}Registrace - Improtřesk 2026{% endblock %}

{% block content %}
<section class="section">
    <div class="container">
        <div class="content" style="max-width: 500px; margin: 0 auto;">
            <div class="header">
                <h3>Registrace nového účtu</h3>
            </div>

            {% if success %}
                <div class="alert alert-success">
                    {{ success }}
                </div>
            {% endif %}

    <form id="register-form" action="/register" method="post">
    <input type="hidden" name="_csrf" value="{{ csrf }}"/>
    <div class="form-group">
        <label class="form-label">Jméno a příjmení:</label>
        <input name="name" type="text" id="register-name" class="form-control" required>
    </div>
    <div class="form-group">
        <label class="form-label">Email:</label>
        <input name="email" type="email" id="register-email" class="form-control" required>
    </div>    
    <div class="form-group">
        <label class="form-label">Heslo:</label>
        <input name="password" type="password" id="register-password" class="form-control" required>
    </div>
    <div class="form-group" style="display:flex; align-items:flex-start; gap:0.5rem; margin-top:0.75rem;">
        <input type="checkbox" id="ticket-only" name="ticket_only" value="1" style="margin-top:0.2rem; flex-shrink:0;">
        <label for="ticket-only" style="cursor:pointer; margin:0;">Chci jenom vstupenku na celovečerní program</label>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn--primary">Registrovat</button>
    </div>
    <div>Registrováním na tomto webu souhlasíte s tím, že váš mail bude použit k&nbsp;zasílání informací k&nbsp;aktuálnímu ročníku Improtřesku, 
    a v&nbsp;případě zaplacení  workshopů i&nbsp;k&nbsp;(max jeden ročně) informacím o dalších ročnících festivalu.
    
     </div>
</form>

        </div>
    </div>
</section>
{% endblock %}
