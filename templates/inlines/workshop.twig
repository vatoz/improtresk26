    <strong class="wts-card__name">{{ workshop.name }}</strong>
    {% if workshop.instructor %}
        <span class="wts-card__meta">{{ workshop.instructor }}</span>
    {% endif %}
    <span class="wts-card__meta">
        {% set _ts = timeslot is defined ? timeslot : (ts is defined ? ts : null) %}
        {% if _ts and _ts.start_datetime %}{{ _ts.start_datetime|date('j.n.Y H:i') }}{% endif %}
        {% if _ts and _ts.end_datetime %}&nbsp;– {{ _ts.end_datetime|date('H:i') }}<br>{% endif %}
        {% if _ts and _ts.duration_minutes %}&nbsp;·&nbsp;{{ _ts.duration_minutes }} min<br>{% endif %}
    </span>
    <span class="wts-card__meta">
        {{ workshop.price|number_format(0, ',', ' ') }} Kč<br>
        &nbsp;·&nbsp;
        {% if workshop.available_spots <= 0 %}
            <span class="wts-badge wts-badge--full">Obsazeno</span><br>
        {% else %}
            volných míst: {{ workshop.available_spots }}<br>
        {% endif %}
         {% if workshop.location %}
            <strong>Místo:</strong> {{ workshop.location }}
        {% endif %}
    </span>


                                    